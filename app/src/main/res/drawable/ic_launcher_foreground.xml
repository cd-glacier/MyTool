<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_launcher_foreground.xml
  D案 (初期版) の前景レイヤー
  シンプルなピッケル(柄+ヘッド+石突きのみ)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ピッケル: translate(54, 62) rotate(20) -->
    <group
        android:pivotX="54"
        android:pivotY="62"
        android:rotation="20">

        <!-- 柄: rect x="-2" y="-22" width="4" height="44" rx="1.5" -->
        <path
            android:pathData="M53.5,40 Q52,40 52,41.5 L52,82.5 Q52,84 53.5,84 L54.5,84 Q56,84 56,82.5 L56,41.5 Q56,40 54.5,40 Z"
            android:fillColor="#FF5D4037"/>

        <!-- ヘッド本体: M -16,-22 Q -2,-26 14,-18 L 12,-14 Q 0,-20 -14,-18 Z -->
        <path
            android:pathData="M38,40 Q52,36 68,44 L66,48 Q54,42 40,44 Z"
            android:fillColor="#FF37474F"/>

        <!-- ピックの上部: M 14,-18 L 22,-14 L 20,-10 L 12,-14 Z -->
        <path
            android:pathData="M68,44 L76,48 L74,52 L66,48 Z"
            android:fillColor="#FF546E7A"/>

        <!-- 石突き: polygon points="-2,22 2,22 0,28" -->
        <path
            android:pathData="M52,84 L56,84 L54,90 Z"
            android:fillColor="#FF37474F"/>

    </group>

</vector>
