<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_launcher_foreground.xml
  D案 (初期版) の前景レイヤー
  シンプルなピッケル(柄+ヘッド+石突きのみ)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ピッケル: translate(54, 50) rotate(20) -->
    <group
        android:pivotX="54"
        android:pivotY="50"
        android:rotation="20">

        <!-- 柄: rect x="-2" y="-22" width="4" height="44" rx="1.5" -->
        <path
            android:pathData="M53.5,28 Q52,28 52,29.5 L52,70.5 Q52,72 53.5,72 L54.5,72 Q56,72 56,70.5 L56,29.5 Q56,28 54.5,28 Z"
            android:fillColor="#FF5D4037"/>

        <!-- ヘッド本体: M -16,-22 Q -2,-26 14,-18 L 12,-14 Q 0,-20 -14,-18 Z -->
        <path
            android:pathData="M38,28 Q52,24 68,32 L66,36 Q54,30 40,32 Z"
            android:fillColor="#FF37474F"/>

        <!-- ピックの上部: M 14,-18 L 22,-14 L 20,-10 L 12,-14 Z -->
        <path
            android:pathData="M68,32 L76,36 L74,40 L66,36 Z"
            android:fillColor="#FF546E7A"/>

        <!-- 石突き: polygon points="-2,22 2,22 0,28" -->
        <path
            android:pathData="M52,72 L56,72 L54,78 Z"
            android:fillColor="#FF37474F"/>

    </group>

</vector>
