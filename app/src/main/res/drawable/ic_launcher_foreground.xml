<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_launcher_foreground.xml
  D案 (初期版) の前景レイヤー
  シンプルなピッケル(柄+ヘッド+石突きのみ)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ピッケル: translate(54, 54) rotate(20) -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="20">

        <!-- 柄: rect x="-2" y="-22" width="4" height="44" rx="1.5" -->
        <path
            android:pathData="M53.5,32 Q52,32 52,33.5 L52,74.5 Q52,76 53.5,76 L54.5,76 Q56,76 56,74.5 L56,33.5 Q56,32 54.5,32 Z"
            android:fillColor="#FF5D4037"/>

        <!-- ヘッド本体: M -16,-22 Q -2,-26 14,-18 L 12,-14 Q 0,-20 -14,-18 Z -->
        <path
            android:pathData="M38,32 Q52,28 68,36 L66,40 Q54,34 40,36 Z"
            android:fillColor="#FF37474F"/>

        <!-- ピックの上部: M 14,-18 L 22,-14 L 20,-10 L 12,-14 Z -->
        <path
            android:pathData="M68,36 L76,40 L74,44 L66,40 Z"
            android:fillColor="#FF546E7A"/>

        <!-- 石突き: polygon points="-2,22 2,22 0,28" -->
        <path
            android:pathData="M52,76 L56,76 L54,82 Z"
            android:fillColor="#FF37474F"/>

    </group>

</vector>
