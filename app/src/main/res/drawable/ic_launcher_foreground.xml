            android:pathData="M53.5,36 Q52,36 52,37.5 L52,78.5 Q52,80 53.5,80 L54.5,80 Q56,80 56,78.5 L56,37.5 Q56,36 54.5,36 Z"
            android:fillColor="#FF5D4037"/>

        <!-- ヘッド本体: M -16,-22 Q -2,-26 14,-18 L 12,-14 Q 0,-20 -14,-18 Z -->
        <path
            android:pathData="M38,36 Q52,32 68,40 L66,44 Q54,38 40,40 Z"
            android:fillColor="#FF37474F"/>

        <!-- ピックの上部: M 14,-18 L 22,-14 L 20,-10 L 12,-14 Z -->
        <path
            android:pathData="M68,40 L76,44 L74,48 L66,44 Z"
            android:fillColor="#FF546E7A"/>

        <!-- 石突き: polygon points="-2,22 2,22 0,28" -->
        <path
            android:pathData="M52,80 L56,80 L54,86 Z"
            android:fillColor="#FF37474F"/>

    </group>

</vector>
