<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".MyToolApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyTool">

        <!-- Icon pack meta-data for launchers (ADW / Nova / Apex) -->
        <meta-data
            android:name="org.adw.launcher.icons.ACTION_PICK_ICON"
            android:resource="@xml/appfilter" />
        <meta-data
            android:name="com.novalauncher.THEME"
            android:resource="@xml/appfilter" />
        <meta-data
            android:name="org.adwlauncher.action.PICK_ICON"
            android:resource="@xml/appfilter" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyTool">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Icon pack discovery: ADW / Apex launcher -->
            <intent-filter>
                <action android:name="org.adw.launcher.icons.ACTION_PICK_ICON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Icon pack discovery: OPPO ColorOS / most launchers (primary intent) -->
            <intent-filter>
                <action android:name="org.adw.launcher.THEMES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Glance Widget Receiver -->
        <receiver
            android:name=".widget.JournalTodoWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/journal_todo_widget_info" />
        </receiver>

        <!-- Widget Config Activity -->
        <activity
            android:name=".widget.JournalTodoWidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.MyTool">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
    </application>

</manifest>
